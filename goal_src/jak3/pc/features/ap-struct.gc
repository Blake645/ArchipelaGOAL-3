 #|(defun ap-trap-received! ((trap symbol))
  (when (and (> (-> *ap-info-jak3* trap-duration) 0.0)
             (task-closed? "arena-")
             (zero? (-> *ap-info-jak3* completed)))
    (sound-play "timer-warn")
      (case trap
      ;; jak 1 ap traps (ordered in the same way)
        (('trip) ;; trip trap
          (process-spawn-function process
            (lambda :behavior process ()
              (send-event *target* 'loading)
              (if (> (-> *ap-info-jak3* trap-duration) 5.0)
                (dotimes (i (- (/ (the int (-> *ap-info-jak3* trap-duration)) 5) 1))
                  (suspend-for (seconds 5))
                  (send-event *target* 'loading))))))
        (('ice-physics) ;; slip trap
          (process-spawn-function process
            (lambda :behavior process ()
              (set! (-> *stone-surface* slope-slip-angle) 16384.0)
              (set! (-> *stone-surface* slip-factor) 0.7)
              (set! (-> *stone-surface* transv-max) 1.5)
              (set! (-> *stone-surface* turnv) 0.5)
              (set! (-> *stone-surface* nonlin-fric-dist) 4091904.0)
              (set! (-> *stone-surface* fric) 23756.8)
              (set! (-> *gravel-surface* slope-slip-angle) 16384.0)
              (set! (-> *gravel-surface* slip-factor) 0.7)
              (set! (-> *gravel-surface* transv-max) 1.5)
              (set! (-> *gravel-surface* turnv) 0.5)
              (set! (-> *gravel-surface* nonlin-fric-dist) 4091904.0)
              (set! (-> *gravel-surface* fric) 23756.8)
              (suspend-for (seconds (-> *ap-info-jak3* trap-duration)))
              (set! (-> *stone-surface* slope-slip-angle) 8192.0)
              (set! (-> *stone-surface* slip-factor) 1.0)
              (set! (-> *stone-surface* transv-max) 1.0)
              (set! (-> *stone-surface* turnv) 1.0)
              (set! (-> *stone-surface* nonlin-fric-dist) 5120.0)
              (set! (-> *stone-surface* fric) 153600.0)
              (set! (-> *gravel-surface* slope-slip-angle) 16384.0)
              (set! (-> *gravel-surface* slip-factor) 1.0)
              (set! (-> *gravel-surface* transv-max) 1.0)
              (set! (-> *gravel-surface* turnv) 1.0)
              (set! (-> *gravel-surface* nonlin-fric-dist) 4096.0)
              (set! (-> *gravel-surface* fric) 122880.0))))
        (('the-big-apple) ;; gravity trap
          (process-spawn-function process
            (lambda :behavior process ()
              (*! (-> *standard-dynamics* gravity-length) 3.0)
              (*! (-> *target* control dynam gravity-length) 3.0)
              (set! (-> *TARGET-bank* fall-far) (meters 2.5))
              (set! (-> *TARGET-bank* fall-far-inc) (meters 3.5))
              (suspend-for (seconds (-> *ap-info-jak3* trap-duration)))
              (/! (-> *standard-dynamics* gravity-length) 3.0)
              (/! (-> *target* control dynam gravity-length) 3.0)
              (set! (-> *TARGET-bank* fall-far) (meters 30))
              (set! (-> *TARGET-bank* fall-far-inc) (meters 20)))))
        (('caught-in-4k) ;; camera trap
          (process-spawn-function process
            (lambda :behavior process ()
              (stack-size-set! (-> self main-thread) 512)
              (set-setting-by-param *setting-control* 'mode-name 'cam-fixed 0 0)
              (suspend-for (seconds (-> *ap-info-jak3* trap-duration)))
              (remove-setting-by-arg0 *setting-control* 'mode-name))))
        (('daredevil) ;; darkness trap
          (process-spawn-function process
            (lambda :behavior process ()
              (send-event (ppointer->process *time-of-day*) 'change 'ratio 0.0)
              (set! (-> *time-of-day-context* mode) (the-as time-of-day-palette-id (/ (the-as int 16384) 8)))
              (suspend-for (seconds (-> *ap-info-jak3* trap-duration)))
              (send-event (ppointer->process *time-of-day*) 'change 'ratio 1.0))))
        (('caseoh) ;; earthquake trap
          (process-spawn-function process
            (lambda :behavior process ()
              (suspend-for (seconds 1))
              (activate! *camera-smush-control* 3000.0 50 (the int (seconds (-> *ap-info-jak3* trap-duration))) 1.0 1.0 (-> self clock))
              (dotimes (i (* 100 (the int (-> *ap-info-jak3* trap-duration))))
                (set! (-> *standard-dynamics* gravity x) (* 3.0 (the float (update! *camera-smush-control*))))
                (suspend-for (seconds 0.01))
                (set! (-> *standard-dynamics* gravity z) (* 3.0 (the float (update! *camera-smush-control*))))
                (suspend-for (seconds 0.01))))))
        (('instant-transmission) ;; teleport trap
          (process-spawn-function process
            (lambda :behavior process ()
              (suspend-for (seconds 1))
              (while (movie?) (suspend-for (seconds 1)))
              (set! (-> *game-info* current-continue) (get-continue-by-name *game-info* "ctysluma-alley"))
              (initialize! *game-info* 'die (the-as game-save #f) "ctysluma-alley"))))
        ;; <ap:note> despair trap is much harder to do than i initially throught, come back later when you can figure out the sound     
        (('personal-bubble) ;; pacifism trap
          (process-spawn-function process
            (lambda :behavior process ()
              (set! (-> *TARGET-bank* punch-radius) (meters -1.0))
              (set! (-> *TARGET-bank* spin-radius) (meters -1.0))
              (set! (-> *TARGET-bank* flop-radius) (meters -1.0))
              (set! (-> *TARGET-bank* uppercut-radius) (meters -1.0))
              (suspend-for (seconds (-> *ap-info-jak3* trap-duration)))
              (set! (-> *TARGET-bank* punch-radius) (meters 1.3))
              (set! (-> *TARGET-bank* spin-radius) (meters 2.2))
              (set! (-> *TARGET-bank* flop-radius) (meters 1.4))
              (set! (-> *TARGET-bank* uppercut-radius) (meters 1.0)))))
        ;; <ap:note> ecoless trap doesn't really make sense in jak 2, as there isn't really any eco besides dark jak and the weapons, and the ammoless trap already exists.      
        (('hit-by-bus) ;; no health trap
          (process-spawn-function process
            (lambda :behavior process ()
              (let ((curr-health (-> *target* fact health)))
                (send-event *target* 'get-pickup (pickup-type health) -8.0)
                (suspend-for (seconds (-> *ap-info-jak3* trap-duration)))
                (send-event *target* 'get-pickup (pickup-type health) curr-health)))))
        (('rivals-of-aether) ;; ledge trap
          (process-spawn-function process
            (lambda :behavior process ()
              (set! (-> *collide-edge-spec* max-dir-cosa-delta) 999.0)
              (suspend-for (seconds (-> *ap-info-jak3* trap-duration)))
              (set! (-> *collide-edge-spec* max-dir-cosa-delta) 0.6))))
        ;; <ap:note> zoomer trap doesn't work (to my knowledge)
        (('man-in-the-mirror) ;; mirror trap
          (process-spawn-function process
            (lambda :behavior process ()
              (logxor! (-> *game-info* secrets) (the-as uint (/ 16 8))) ;; mirror world secret as a bitflag
              (suspend-for (seconds (-> *ap-info-jak3* trap-duration)))
              (logxor! (-> *game-info* secrets) (the-as uint (/ 16 8)))
              )
          ))
        ;; <ap:todo> ammo trap, forced dark jak trap, no health trap, etc (i'm still trying to think of more to include)
        ;; jak 2 ap traps, commenting out stuff that won't work for jak 3
        ;; (('five-star) ;; high alert trap
        ;;  (process-spawn-function process
        ;;    (lambda :behavior process ()
        ;;      (stack-size-set! (-> self main-thread) 512)
        ;;      (send-event *traffic-manager* 'set-max-alert-level 5)
        ;;      (send-event *traffic-manager* 'set-alert-level 5)
        ;;      (suspend-for (seconds (-> *ap-info-jak3* trap-duration)))
        ;;      (send-event *traffic-manager* 'set-alert-level 0))))
        (('russian-roulette) ;; ammo trap
          (process-spawn-function process
            (lambda :behavior process ()
              (stack-size-set! (-> self main-thread) 1024)
              (let ((curr-red (-> *game-info* gun-ammo (- (pickup-type ammo-red) 13)))
                    (curr-yellow (-> *game-info* gun-ammo (- (pickup-type ammo-yellow) 13)))
                    (curr-blue (-> *game-info* gun-ammo (- (pickup-type ammo-blue) 13)))
                    (curr-dark (-> *game-info* gun-ammo (- (pickup-type ammo-dark) 13))))
                    (send-event *target* 'get-pickup (pickup-type ammo-red) -100.0)
                    (send-event *target* 'get-pickup (pickup-type ammo-yellow) -200.0)
                    (send-event *target* 'get-pickup (pickup-type ammo-blue) -200.0)
                    (send-event *target* 'get-pickup (pickup-type ammo-dark) -10.0)
                    (suspend-for (seconds (-> *ap-info-jak3* trap-duration)))
                    (send-event *target* 'get-pickup (pickup-type ammo-red) curr-red)
                    (send-event *target* 'get-pickup (pickup-type ammo-yellow) curr-yellow)
                    (send-event *target* 'get-pickup (pickup-type ammo-blue) curr-blue)
                    (send-event *target* 'get-pickup (pickup-type ammo-dark) curr-dark)))))
        (('anger-issues) ;; forced dark jak trap
          (process-spawn-function process
            (lambda :behavior process ()
              (send-event *target* 'change-mode 'darkjak #f (darkjak-stage force-on active))
              (suspend-for (seconds (-> *ap-info-jak3* trap-duration)))
              (while (logtest? (-> *target* control current-surface flags) (surface-flag air)) ;; if jak is in the air, wait until he lands
                (suspend)
              )
              (send-event *target* 'change-mode 'normal))))
        (('sonic-speed) ;; speed trap
          (process-spawn-function process
            (lambda :behavior process ()
              (update-rates! (-> *display* entity-clock) (* 60.0 (-> *display* entity-clock clock-ratio)))
              (update-rates! (-> *display* target-clock) (* 2.0 (-> *display* target-clock clock-ratio)))
              (suspend-for (seconds (-> *ap-info-jak3* trap-duration)))
              (update-rates! (-> *display* entity-clock) (/ 60.0 (-> *display* entity-clock clock-ratio)))
              (update-rates! (-> *display* target-clock) (/ 2.0 (-> *display* target-clock clock-ratio)))
              )))
        (('la-traffic) ;; slow trap
          (process-spawn-function process
            (lambda :behavior process ()
              (update-rates! (-> *display* entity-clock) (* 0.3 (-> *display* entity-clock clock-ratio)))
              (update-rates! (-> *display* target-clock) (* 0.5 (-> *display* target-clock clock-ratio)))
              (suspend-for (seconds (-> *ap-info-jak3* trap-duration)))
              (update-rates! (-> *display* entity-clock) (/ 0.3 (-> *display* entity-clock clock-ratio)))
              (update-rates! (-> *display* target-clock) (/ 0.5 (-> *display* target-clock clock-ratio))))))
        (('hardcore) ;; hero mode trap :D
          (process-spawn-function process
            (lambda :behavior process ()
              (logxor! (-> *game-info* secrets) (game-secrets hero-mode))
              (suspend-for (seconds (-> *ap-info-jak3* trap-duration)))
              (logxor! (-> *game-info* secrets) (game-secrets hero-mode)))))
        ))
    (and (> (-> *ap-info-jak3* trap-duration) 0.0)
             (task-closed? "arena-fight-1")
             (zero? (-> *ap-info-jak3* completed))))

(defun ap-route-spargus-to-desert? ()
  (or (logtest? (-> *game-info* features) (game-feature pass-front-gate vehicle-turtle))    ;; each different car
  (logtesta? (-> *game-info* features) (game-feature pass-front-gate vehicle-snake))
  (logtesta? (-> *game-info* features) (game-feature pass-front-gate vehicle-scorpion))
  (logtesta? (-> *game-info* features) (game-feature pass-front-gate vehicle-toad))
  (logtesta? (-> *game-info* features) (game-feature pass-front-gate vehicle-fox))
  (logtesta? (-> *game-info* features) (game-feature pass-front-gate vehicle-rhino))
  (logtesta? (-> *game-info* features) (game-feature pass-front-gate vehicle-mirage))
  (logtesta? (-> *game-info* features) (game-feature pass-front-gate vehicle-x-ride))
      )
  )

(defun ap-route-spargus-to-monk-temple? ()
  (or (logtest? (-> *game-info* features) (game-feature pass-front-gate vehicle-toad))       ;; direct route.
      )
  )

(defun ap-route-slums-to-port? ()
  (or (logtesta? (-> *game-info* features) (game-feature pass-front-gate pass-air-train))            ;; direct route
      )
  )

(defun ap-route-port-to-stadium? ()
  (or (logtest? (-> *game-info* features) (game-feature pass-yellow))                        ;; direct route.
      (logtesta? (-> *game-info* features) (game-feature pass-red pass-green))               ;; through slums.
      (logtesta? (-> *game-info* features) (game-feature pass-air-train board pass-green))   ;; pumping station + green pass.
      )
  )

(defun ap-route-port-to-market? ()
  (logtest? (-> *game-info* features) (game-feature pass-yellow))  ;; there is no way into the market without yellow pass.
  )

(defun ap-route-market-to-stadium? ()
  (logtest? (-> *game-info* features) (game-feature pass-yellow))  ;; there is no way OUT OF the market without yellow pass.
  )

(defun ap-route-slums-to-landing? ()
  (or (logtest? (-> *game-info* features) (game-feature board))                                   ;; pumping station.
      (logtesta? (-> *game-info* features) (game-feature pass-red pass-air-train))                ;; through port.
      (logtesta? (-> *game-info* features) (game-feature pass-green pass-yellow pass-air-train))  ;; through stadium town and farms.
      )
  )

(defun ap-route-slums-to-nest? ()
  (or (logtesta? (-> *game-info* features) (game-feature board pass-air-train))                   ;; pumping station.
      (logtesta? (-> *game-info* features) (game-feature pass-red pass-air-train))                ;; through port.
      (logtesta? (-> *game-info* features) (game-feature pass-green pass-yellow pass-air-train))  ;; through stadium town and farms.
      )
  )

(defun ap-setup-options! ((options ap-seed-options))
  (set! (-> *ap-settings* completion-type) (-> options completion-type))
  (set! (-> *ap-settings* completion-value) (-> options completion-value))
  (set! (-> *ap-settings* trap-duration) (-> options trap-duration))
  ;; <ap:todo> do this later
  ;; (charp<-string (-> *ap-info-jak3* slot-name) (-> options slot-name))
  ;; (charp<-string (-> *ap-info-jak3* slot-seed) (-> options slot-seed))
  #t)

(defun ap-settings-update ()
  ;; <ap:todo> deathlink will come later, leave it out for now
  ;; (set! (-> *ap-info-jak3* deathlink-enabled) (if (-> *ap-settings* deathlink?) 1 0))
  (set! (-> *ap-info-jak3* trap-duration) (-> *ap-settings* trap-duration))
  (set! (-> *ap-info-jak3* completion-goal-type) (the-as ap-completion-type (-> *ap-settings* completion-type)))
  (set! (-> *ap-info-jak3* completion-goal-value) (-> *ap-settings* completion-value))
  (none)
)
|#